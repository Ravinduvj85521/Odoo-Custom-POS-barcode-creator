<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="label_57x35">
        <table class="table" style="margin: 0; padding: 0; ">
            <tbody style="border: 0;">
                <tr height="100px" style="border:0;margin:0;padding:0;">
                    <td class="col-xs-4 text-center" style="border:0;margin:0;padding:0;">
                        <div style="border:1px solid grey; border-radius:10px; width:100%;padding:2px 0">

                        <div style="width: 100%; padding: 0;; margin: 0; font-size: 12px; ">
                            <t t-set="pl57" t-value="label.wizard_id.pricelist_id"/>
                            <t t-set="price57" t-value="pl57._get_product_price(label.product_id, 1.0) if pl57 else label.product_id.lst_price"/>
                            <t t-set="currency57" t-value="pl57.currency_id if pl57 else label.product_id.currency_id"/>
                            <span t-if="currency57.position == 'before'" t-esc="currency57.symbol"/>
                            <span t-esc="'%.2f' % price57"/>
                            <span t-if="currency57.position == 'after'" t-esc="currency57.symbol"/>
                        </div>

                        <t t-if="label.product_id.barcode">
                            <div t-out="label.product_id.barcode" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'overflow: hidden; width: 100%; height: 1.6rem;', 'humanreadable': label.wizard_id.humanreadable}" class="px-1"/>
                        </t>
                        <div t-if="label.product_id.default_code" style="width: 100%; padding: 0; margin: 0; font-size: 8px;">
                            <span t-field="label.product_id.default_code"/>
                        </div>
                        <div style="overflow:hidden;line-height:12px">
                             <span t-field="label.product_id.name" style="font-size:10px; "/>
                             <span t-if="label.product_id.product_template_attribute_value_ids"
                                   t-esc="u', '.join(map(lambda x: x.attribute_line_id.attribute_id.name + u': ' + x.name, label.product_id.product_template_attribute_value_ids))"
                                   class="badge"/>
                        </div>
                        </div>

                    </td>
                </tr>
            </tbody>
        </table>
    </template>

    <template id="report_product_label_57x35_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-set="count" t-value="0" />
                <div class="page">
                    <div class="oe_structure"/>
                    <t t-foreach="docs" t-as="label">
                        <t t-set="qty" t-value="1" />
                        <t t-if="label.qty">
                            <t t-set="qty" t-value="label.qty" />
                        </t>
                        <t t-foreach="list(range(qty))" t-as="index_qty">
                            <div t-if="count % 36 == 0" style="page-break-after:always;"/>
                            <div t-if="count % 4 == 0" style="clear:both;"/>
                            <div t-att-style="'width: 170px; float: left; margin:5px; height: 100px;  '.format('%dpx solid #777;' % label.wizard_id.border_width if label.wizard_id.border_width else '0') ">
                                <t t-call="custom_product_label.label_57x35"/>
                            </div>
                            <t t-set="count" t-value="count+1" />
                        </t>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <template id="report_product_label_50x38_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="label">
                    <t t-set="qty" t-value="1"/>
                    <t t-if="label.qty" t-set="qty" t-value="label.qty" />
                    <t t-foreach="list(range(qty))" t-as="index_qty">
                        <div class="page" style="page-break-after: always;">
                            <div style="height: 136px !important; width: 165px !important;">
                                <table class="table" t-att-style="'height: 100%; border: {};'.format('%dpx solid #777;' % label.wizard_id.border_width if label.wizard_id.border_width else '0')">
                                    <tbody style="border: 0;">
                                        <tr style="border: 0;">
                                            <td class="text-center" style="padding: 0; margin: 0; border: 0;">
                                                <div style="overflow: hidden; height: 64px !important; font-size: 13px; line-height: 1.2; margin-bottom: 2px;">
                                                    <span t-field="label.product_id.name" style="line-height: 1.2;"/>
                                                    <span t-if="label.product_id.product_template_attribute_value_ids"
                                                          t-esc="u', '.join(map(lambda x: x.attribute_line_id.attribute_id.name + u': ' + x.name, label.product_id.product_template_attribute_value_ids))"
                                                          class="badge"/>
                                                </div>
                                                <div style="width: 100%; overflow: hidden; height: 26px !important;">
                                                    <div style="float: right; width: 60%; font-size: 20px; font-weight: bold; line-height: 1.0; text-align: right; margin-bottom: 0px;">
                                                        <t t-set="pl50" t-value="label.wizard_id.pricelist_id"/>
                                                        <t t-set="price50" t-value="pl50._get_product_price(label.product_id, 1.0) if pl50 else label.product_id.lst_price"/>
                                                        <t t-set="currency50" t-value="pl50.currency_id if pl50 else label.product_id.currency_id"/>
                                                        <span t-if="currency50.position == 'before'" t-esc="currency50.symbol"/>
                                                        <span t-esc="'%.2f' % price50"/>
                                                        <span t-if="currency50.position == 'after'" t-esc="currency50.symbol"/>
                                                    </div>
                                                    <div style="float: left; width: 40%; font-size: 10px; font-weight: 900; line-height: 1.0; text-align: left; margin-bottom: 0px; padding-top: 6px;">
                                                        <span t-if="label.product_id.default_code"><span t-field="label.product_id.default_code"/> </span>
                                                    </div>
                                                </div>
                                                <t t-if="label.product_id.barcode">
                                                    <div t-out="label.product_id.barcode" style="margin-top: 5px;" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': 'overflow: hidden; width: 100%; height: 2.0rem;', 'humanreadable': label.wizard_id.humanreadable}"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <template id="report_product_label_66x25_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="label">
                    <t t-set="qty" t-value="1"/>
                    <t t-if="label.qty" t-set="qty" t-value="label.qty" />
                    <t t-foreach="list(range(qty))" t-as="index_qty">
                        <div class="page" style="page-break-after: always;">
                            <div style="height: 89px !important; width: 218px !important;">
                                <table class="table" t-att-style="'height: 100%; border: {};'.format('%dpx solid #777;' % label.wizard_id.border_width if label.wizard_id.border_width else '0')">
                                    <tbody style="border: 0;">
                                        <tr height="89px" style="border: 0;">
                                            <td class="text-center" style="padding: 0; margin: 0; border: 0;">
                                                <div style="overflow: hidden; height: 45px !important; font-size: 13px; line-height: 1.175; margin-bottom: 3px; text-align: left;">
                                                    <span t-field="label.product_id.name" style="line-height: 1.175;"/>
                                                    <span t-if="label.product_id.product_template_attribute_value_ids"
                                                          t-out="u', '.join(map(lambda x: x.attribute_line_id.attribute_id.name + u': ' + x.name, label.product_id.product_template_attribute_value_ids))"
                                                          class="badge"/>
                                                </div>
                                                <div style="width: 100%; overflow: hidden; height: 40px !important;">
                                                    <div style="float: left; width: 60%; font-size: 20px; font-weight: bold; line-height: 1.0; text-align: right; margin-bottom: 0px;">
                                                        <t t-if="label.product_id.barcode" style="height: 16px !important; margin: 2px 0;">
                                                            <div t-out="label.product_id.barcode" style="margin-left: 2px;" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': 'overflow: hidden; width: 100%; height: 1.5rem;', 'humanreadable': label.wizard_id.humanreadable}"/>
                                                            <div t-if="not label.wizard_id.humanreadable" t-field="label.product_id.barcode" style="font-size: 10px; font-weight: normal; text-align: left; margin-left: 2px; margin-top: 2px;"/>
                                                        </t>
                                                    </div>
                                                    <div style="float: right; width: 40%;">
                                                        <div style="width: 100%; font-size: 16px; font-weight: 900; line-height: 1.0; text-align: right; margin-bottom: 2px;">
                                                            <span t-if="label.product_id.currency_id.position == 'before'" t-field="label.product_id.currency_id.symbol"/>
                                                            <span t-field="label.product_id.lst_price"/>
                                                            <span t-if="label.product_id.currency_id.position == 'after'" t-field="label.product_id.currency_id.symbol"/>
                                                        </div>
                                                        <div t-if="label.product_id.default_code" style="width: 100%; font-size: 9px; font-weight: 900; line-height: 1.0; text-align: center; background: #000; color: #FFF; margin-left: 3px;">
                                                            <span t-field="label.product_id.default_code"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <template id="report_product_label_from_template">
        <t t-call="web.basic_layout"/>
    </template>

</odoo>
